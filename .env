# 🔒 Arquivo oculto para senhas (ex: conexão com banco de dados)
# tracebox/.env

# Mude para 'postgres' quando for para a nuvem
DB_TYPE=sqlite 

# Configuração SQLite (Desenvolvimento)
SQLITE_PATH=estoque_ferramentas.db

# Configurações PostgreSQL (Para o futuro no Supabase/AWS)
PG_HOST=localhost
PG_DATABASE=tracebox_db
PG_USER=postgres
PG_PASSWORD=sua_senha_segura
PG_PORT=5432