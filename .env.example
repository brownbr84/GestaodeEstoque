# TraceBox WMS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.

# ─────────────────────────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────────────────────────
# Mude para 'postgres' em produção
DB_TYPE=sqlite

# SQLite (desenvolvimento local)
SQLITE_PATH=estoque_ferramentas.db

# PostgreSQL (produção)
PG_HOST=localhost
PG_DATABASE=tracebox_db
PG_USER=postgres
PG_PASSWORD=SUBSTITUA_PELA_SENHA_REAL
PG_PORT=5432

# ─────────────────────────────────────────────────────────────────
# SEGURANÇA — JWT
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=SUBSTITUA_POR_VALOR_ALEATORIO_DE_64_CHARS_HEX

# ─────────────────────────────────────────────────────────────────
# SEGURANÇA — Fernet (criptografia SMTP no BD)
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ─────────────────────────────────────────────────────────────────
FERNET_KEY=SUBSTITUA_POR_CHAVE_FERNET_GERADA
